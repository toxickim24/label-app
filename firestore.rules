rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isMaster() {
      return isAuthenticated() && getUserRole() == 'master';
    }

    function isAdminOrMaster() {
      return isAuthenticated() && getUserRole() in ['admin', 'master'];
    }

    function hasPermission(permitType, permission) {
      return isAuthenticated() &&
             getUserData().permissions[permitType][permission] == true;
    }

    // ============================================
    // USERS COLLECTION
    // ============================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdminOrMaster()) &&
                       // Validate notification preferences if present
                       (!('notificationPreferences' in request.resource.data) ||
                        (request.resource.data.notificationPreferences.keys().hasAll(['enabled', 'dailyLeadNotification', 'staleLeadReminders', 'newLeadAlerts', 'notificationTime']) &&
                         request.resource.data.notificationPreferences.enabled is bool &&
                         request.resource.data.notificationPreferences.dailyLeadNotification is bool &&
                         request.resource.data.notificationPreferences.staleLeadReminders is bool &&
                         request.resource.data.notificationPreferences.newLeadAlerts is bool &&
                         request.resource.data.notificationPreferences.notificationTime is string));
      allow delete: if false;
    }

    // ============================================
    // LEADS COLLECTION
    // ============================================

    match /leads/{leadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
                       // Validate status is one of the allowed values
                       (!('status' in request.resource.data) ||
                        request.resource.data.status in ['new', 'contacted', 'engaged', 'est_sent', 'appointment', 'closing', 'responded', 'qualified', 'disqualified', 'converted', 'invalid']) &&
                       // Validate statusHistory is an array if present
                       (!('statusHistory' in request.resource.data) ||
                        request.resource.data.statusHistory is list) &&
                       // Validate contactedCount is a number if present
                       (!('contactedCount' in request.resource.data) ||
                        request.resource.data.contactedCount is int) &&
                       // Validate lastContactedAt is timestamp if present
                       (!('lastContactedAt' in request.resource.data) ||
                        request.resource.data.lastContactedAt == null ||
                        request.resource.data.lastContactedAt is timestamp) &&
                       // Validate lastContactedBy is string if present
                       (!('lastContactedBy' in request.resource.data) ||
                        request.resource.data.lastContactedBy == null ||
                        request.resource.data.lastContactedBy is string);
      allow delete: if isAuthenticated() && isAdminOrMaster();
    }

    // ============================================
    // TEMPLATES COLLECTION
    // ============================================

    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // POLICIES COLLECTION
    // ============================================

    match /policies/{policyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isMaster();
    }

    // ============================================
    // API KEYS COLLECTION
    // ============================================

    match /api_keys/{keyId} {
      allow read: if isAuthenticated() && isAdminOrMaster();
      allow write: if isAuthenticated() && isMaster();
    }

    // ============================================
    // CONFIG COLLECTION
    // ============================================

    match /config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isMaster();
    }

    // ============================================
    // OTHER COLLECTIONS
    // ============================================

    match /permits/{permitId} {
      allow read, write: if isAuthenticated();
    }

    match /ai_prompts/{promptId} {
      allow read, write: if isAuthenticated();
    }

    match /acceptance_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && isAdminOrMaster();
      allow write: if false;
    }

    // ============================================
    // DEFAULT DENY ALL
    // ============================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
